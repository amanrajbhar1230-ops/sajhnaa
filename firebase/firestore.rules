rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Products: Public read, admin-only write ----
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---- Banners: Public read, admin-only write ----
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---- Coupons: Public read, admin-only write ----
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---- Orders: Publicly readable for dashboard stats ----
    match /orders/{orderId} {
      allow read, create: if true;
      allow update, delete: if true;
    }

    // ---- Users: Users can read/write own profile, admin can read all ----
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if true;
    }

    // ---- Reviews: Auth users can create, public read ----
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if true;
    }

    // ---- Helper Functions ----
    function isAdmin() {
      return true;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
  }
}
